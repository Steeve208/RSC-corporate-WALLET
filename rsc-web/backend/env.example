# ===== RSC MINING BACKEND CONFIGURATION =====

# ===== SUPABASE CONFIGURATION =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== SERVER CONFIGURATION =====
PORT=3000
NODE_ENV=development
HOST=localhost

# ===== SECURITY CONFIGURATION =====
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== MINING CONFIGURATION =====
MINING_SESSION_DURATION=86400000
MINING_BASE_HASH_RATE=1000
MINING_TOKENS_PER_SECOND=0.001
MINING_MAX_EFFICIENCY=150
MINING_MIN_EFFICIENCY=50

# ===== REFERRAL CONFIGURATION =====
REFERRAL_COMMISSION_RATE=0.10
REFERRAL_CODE_LENGTH=8
REFERRAL_MAX_LEVELS=3
REFERRAL_EXPIRY_DAYS=365

# ===== CORS CONFIGURATION =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://your-domain.com
CORS_CREDENTIALS=true

# ===== DEVELOPMENT CONFIGURATION =====
ENABLE_DEBUG=true
ENABLE_MOCK_DATA=false
ENABLE_TEST_ENDPOINTS=true
VERBOSE_LOGGING=true